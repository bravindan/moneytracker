# Firebase Project Configuration
# ─────────────────────────────────────────────────────────────────────────────
# 1. Go to https://console.firebase.google.com → your project → Project Settings
# 2. Under "Your apps" add a Web app (or use an existing one)
# 3. Copy the firebaseConfig values below
# 4. Rename this file to .env  (it is already git-ignored)
#
# Expo automatically injects variables prefixed with EXPO_PUBLIC_ into the
# JavaScript bundle, so no extra package is needed.
# ─────────────────────────────────────────────────────────────────────────────

EXPO_PUBLIC_FIREBASE_API_KEY=your_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_app_id

# Google OAuth — needed for "Continue with Google" sign-in
# Create OAuth 2.0 Client IDs at https://console.cloud.google.com/apis/credentials
# Web client: Application type → Web application
# Android client: Application type → Android  (use your app's SHA-1 + package name)
# iOS client: Application type → iOS  (use your bundle identifier)
EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=your_web_client_id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=your_ios_client_id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=your_android_client_id.apps.googleusercontent.com
